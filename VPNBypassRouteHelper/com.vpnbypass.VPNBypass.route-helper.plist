<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Template launchd plist for the privileged helper Mach service.
  Production install: SMJobBless copies this to /Library/LaunchDaemons/ (or equivalent) and loads it.
  The Label and MachServices key must match RouteXPCConstants.machServiceName.
-->
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.vpnbypass.VPNBypass.route-helper</string>
	<key>MachServices</key>
	<dict>
		<key>com.vpnbypass.VPNBypass.route-helper</key>
		<true/>
	</dict>
	<key>ProgramArguments</key>
	<array>
		<string>/Library/PrivilegedHelperTools/VPNBypassRouteHelper</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
</dict>
</plist>
